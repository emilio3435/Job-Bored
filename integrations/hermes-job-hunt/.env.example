# Hermes Job Hunt OS (JHOS) — optional, local-only materials workflow.
# Copy this file to `integrations/hermes-job-hunt/.env` (gitignored) and fill in
# values, OR export these in your shell. Placeholder values only.
#
# NOTE: Hermes itself reads its LLM/tool/messaging keys from ~/.hermes/.env
# (created by `hermes setup`), not from this file. The variables below are the
# ones the JobBored Hermes scripts in this folder read directly. Hermes scripts
# also fall back to ~/.hermes/.env for TELEGRAM_BOT_TOKEN.

# --- LLM for the universal form filler / drafting ---
# OpenRouter routes to many models with one key. https://openrouter.ai/keys
# Hermes can also read this from ~/.hermes/.env.
OPENROUTER_API_KEY=
# Model used by the form filler (default anthropic/claude-sonnet-4.5).
JHOS_FILLER_MODEL=anthropic/claude-sonnet-4.5

# --- Pipeline Google Sheet (submit + status scripts) ---
# The Pipeline Sheet ID (the long token in the spreadsheet URL).
JHOS_SHEET_ID=
# Short-lived Google Sheets OAuth access token for write-back. Usually passed
# via --access-token; set here to default it. https://console.cloud.google.com/
JHOS_ACCESS_TOKEN=

# --- Telegram approval gates (optional) ---
# Bot token from @BotFather (https://t.me/BotFather). Falls back to ~/.hermes/.env.
TELEGRAM_BOT_TOKEN=
# Chat/channel ID the approval gate posts to.
TELEGRAM_HOME_CHANNEL=

# --- Approval gate control flags (advanced; usually set by the orchestrator) ---
# Set to "1" to bypass the Gate 2 confirmation prompt for an assisted submit.
JHOS_GATE2_CONFIRMED=
# Set to "1" to skip the script's auto re-exec into ~/.hermes/job-hunt/.venv.
HERMES_SKIP_VENV_REEXEC=

# --- TLS (optional) ---
# Path to a CA bundle (certifi) for Google API calls behind strict TLS.
# Scripts auto-detect a bundled cert if present; override only if needed.
SSL_CERT_FILE=
