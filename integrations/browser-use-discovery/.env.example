# Browser Use-backed discovery worker
# Copy this file to `.env` or feed it to your process manager.

# Local QA default. Use `hosted` when you deploy the worker on a public host.
BROWSER_USE_DISCOVERY_RUN_MODE=local
BROWSER_USE_DISCOVERY_HOST=127.0.0.1
BROWSER_USE_DISCOVERY_PORT=8644

# Where the worker persists its config and state. Packaged local setup uses
# ~/.jobbored so secrets/state do not live inside the git checkout.
BROWSER_USE_DISCOVERY_WORKER_CONFIG=~/.jobbored/browser-use-discovery/worker-config.json
BROWSER_USE_DISCOVERY_CONFIG_PATH=~/.jobbored/browser-use-discovery/worker-config.json
BROWSER_USE_DISCOVERY_WORKER_ENV=~/.jobbored/browser-use-discovery/.env
BROWSER_USE_DISCOVERY_ENV_FILE=~/.jobbored/browser-use-discovery/.env
BROWSER_USE_DISCOVERY_STATE_DB_PATH=~/.jobbored/browser-use-discovery/worker-state.sqlite

# Browser automation command seam.
# Leave empty to auto-use the bundled wrapper when present:
# ./integrations/browser-use-discovery/bin/browser-use-agent-browser.mjs
# If the wrapper is absent, runtime falls back to `browser-use`.
# Set explicitly to override either default or to force fetch-only behavior in tests.
BROWSER_USE_DISCOVERY_BROWSER_COMMAND=

# Optional Gemini Google-tool grounding for broader web discovery.
BROWSER_USE_DISCOVERY_GEMINI_API_KEY=
BROWSER_USE_DISCOVERY_GEMINI_MODEL=gemini-2.5-flash
BROWSER_USE_DISCOVERY_GROUNDED_SEARCH_MAX_RESULTS_PER_COMPANY=6
BROWSER_USE_DISCOVERY_GROUNDED_SEARCH_MAX_PAGES_PER_COMPANY=4

# Optional SerpApi key — enables the serpapi_google_jobs source lane.
# Queries Google Jobs via https://serpapi.com/ and returns structured
# JobPosting listings with no extraction step. Free tier: 100 searches/mo;
# Developer tier: $50/mo for 5K searches. Lane is skipped when unset.
SERPAPI_API_KEY=

# Optional Browser Use Cloud fallback for Add job from URL.
# Used only when a pasted URL is a blocked aggregator or the normal scrape
# fails/returns weak content. Sync a Browser Use profile for authenticated
# LinkedIn-style pages, then paste the returned profile id below.
BROWSER_USE_API_KEY=
BROWSER_USE_PROFILE_ID=

# Generic chat/JSON LLM tasks: scoring, matching, profile extraction, and
# other provider-neutral worker calls. OpenRouter and local servers use the
# OpenAI-compatible /chat/completions shape.
BROWSER_USE_DISCOVERY_LLM_PROVIDER=
BROWSER_USE_DISCOVERY_LLM_API_KEY=
BROWSER_USE_DISCOVERY_LLM_MODEL=
BROWSER_USE_DISCOVERY_LLM_BASE_URL=
BROWSER_USE_DISCOVERY_OPENROUTER_API_KEY=
BROWSER_USE_DISCOVERY_OPENROUTER_MODEL=openai/gpt-oss-120b:free
BROWSER_USE_DISCOVERY_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
BROWSER_USE_DISCOVERY_OPENAI_COMPATIBLE_API_KEY=
BROWSER_USE_DISCOVERY_OPENAI_COMPATIBLE_MODEL=
BROWSER_USE_DISCOVERY_OPENAI_COMPATIBLE_BASE_URL=
BROWSER_USE_DISCOVERY_LOCAL_API_KEY=
BROWSER_USE_DISCOVERY_LOCAL_MODEL=gemma4:e2b
BROWSER_USE_DISCOVERY_LOCAL_BASE_URL=http://127.0.0.1:11434/v1

# Google Sheets target. Paste the Pipeline Sheet ID (the long token in the
# spreadsheet URL). Either var works; BROWSER_USE_DISCOVERY_SHEET_ID wins.
BROWSER_USE_DISCOVERY_SHEET_ID=
JOBBORED_SHEET_ID=

# Google Sheets auth. Set one of the credential forms below.
BROWSER_USE_DISCOVERY_GOOGLE_ACCESS_TOKEN=
BROWSER_USE_DISCOVERY_GOOGLE_SERVICE_ACCOUNT_JSON=
BROWSER_USE_DISCOVERY_GOOGLE_SERVICE_ACCOUNT_FILE=
BROWSER_USE_DISCOVERY_GOOGLE_OAUTH_TOKEN_JSON=
BROWSER_USE_DISCOVERY_GOOGLE_OAUTH_TOKEN_FILE=

# Optional override for the candidate profile.md used for fit scoring.
# Defaults to integrations/hermes-job-hunt/profile/profile.md.
JOBBORED_PROFILE_PATH=

# Optional webhook hardening.
BROWSER_USE_DISCOVERY_WEBHOOK_SECRET=

# Browser-facing origins allowed by the worker.
BROWSER_USE_DISCOVERY_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Keep async acknowledgements enabled for browser-triggered discovery.
BROWSER_USE_DISCOVERY_ASYNC_ACK=true

# Async discovery watchdog. Defaults to 60 minutes; raise for very broad runs.
BROWSER_USE_DISCOVERY_MAX_RUN_DURATION_MS=3600000
