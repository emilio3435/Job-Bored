# Browser Use-backed discovery worker
# Copy this file to `.env` or feed it to your process manager.

# Local QA default. Use `hosted` when you deploy the worker on a public host.
BROWSER_USE_DISCOVERY_RUN_MODE=local
BROWSER_USE_DISCOVERY_HOST=127.0.0.1
BROWSER_USE_DISCOVERY_PORT=8644

# Where the worker persists its config and state.
BROWSER_USE_DISCOVERY_CONFIG_PATH=./state/worker-config.json
BROWSER_USE_DISCOVERY_STATE_DB_PATH=./state/worker-state.sqlite

# Browser automation command seam.
# Leave empty to auto-use the bundled wrapper when present:
# ./integrations/browser-use-discovery/bin/browser-use-agent-browser.mjs
# If the wrapper is absent, runtime falls back to `browser-use`.
# Set explicitly to override either default or to force fetch-only behavior in tests.
BROWSER_USE_DISCOVERY_BROWSER_COMMAND=

# Optional Gemini grounding for broader web discovery.
BROWSER_USE_DISCOVERY_GEMINI_API_KEY=
BROWSER_USE_DISCOVERY_GEMINI_MODEL=gemini-2.5-flash
BROWSER_USE_DISCOVERY_GROUNDED_SEARCH_MAX_RESULTS_PER_COMPANY=6
BROWSER_USE_DISCOVERY_GROUNDED_SEARCH_MAX_PAGES_PER_COMPANY=4

# Google Sheets auth. Set one of the credential forms below.
BROWSER_USE_DISCOVERY_GOOGLE_ACCESS_TOKEN=
BROWSER_USE_DISCOVERY_GOOGLE_SERVICE_ACCOUNT_JSON=
BROWSER_USE_DISCOVERY_GOOGLE_SERVICE_ACCOUNT_FILE=
BROWSER_USE_DISCOVERY_GOOGLE_OAUTH_TOKEN_JSON=
BROWSER_USE_DISCOVERY_GOOGLE_OAUTH_TOKEN_FILE=

# Optional webhook hardening.
BROWSER_USE_DISCOVERY_WEBHOOK_SECRET=

# Browser-facing origins allowed by the worker.
BROWSER_USE_DISCOVERY_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Keep async acknowledgements enabled for browser-triggered discovery.
BROWSER_USE_DISCOVERY_ASYNC_ACK=true
