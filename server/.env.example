# JobBored local server (Cheerio scraper + ATS scorecard + materials).
# Copy this file to `server/.env` and fill in values. The real `server/.env`
# is gitignored. Placeholder values only — never commit real keys.

# --- HTTP server ---
# Port the local server listens on (default 3847). The dashboard auto-targets
# http://127.0.0.1:3847 on localhost when scrape/ATS URLs are left blank.
PORT=3847
# Bind address (default 127.0.0.1 = local only). Set 0.0.0.0 to expose on LAN.
LISTEN_HOST=127.0.0.1
# Comma-separated origins allowed to call this server (CORS). Any of these works;
# they are checked in order COMMAND_CENTER_ALLOWED_ORIGINS > CORS_ALLOWED_ORIGINS
# > ALLOWED_ORIGINS. Defaults already include localhost:8080.
COMMAND_CENTER_ALLOWED_ORIGINS=
CORS_ALLOWED_ORIGINS=
ALLOWED_ORIGINS=

# --- ATS scorecard provider (POST /api/ats-scorecard) ---
# Which LLM scores resumes: gemini (default), openai, or anthropic.
ATS_PROVIDER=gemini
# Gemini (default provider). Get a key at https://aistudio.google.com/app/apikey
ATS_GEMINI_API_KEY=
ATS_GEMINI_MODEL=gemini-3.5-flash
# OpenAI (only if ATS_PROVIDER=openai). https://platform.openai.com/api-keys
ATS_OPENAI_API_KEY=
ATS_OPENAI_MODEL=gpt-4o-mini
# Anthropic (only if ATS_PROVIDER=anthropic). https://console.anthropic.com/
ATS_ANTHROPIC_API_KEY=
ATS_ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional generic aliases — used as fallbacks if the ATS_*-prefixed key above
# is unset. Handy if you already export these for other tools.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Job discovery search (Google Jobs via SerpApi) ---
# Optional. Enables the server's job-search lane. Get a key at https://serpapi.com/
# (free tier: 100 searches/mo). DISCOVERY_SERPAPI_API_KEY takes precedence, then
# SERPAPI_API_KEY, then the worker's BROWSER_USE_DISCOVERY_SERPAPI_API_KEY.
SERPAPI_API_KEY=
DISCOVERY_SERPAPI_API_KEY=
BROWSER_USE_DISCOVERY_SERPAPI_API_KEY=

# --- Google Sheets access (server-side reads/writes) ---
# Provide ONE credential form. Inline JSON or a file path to a service-account
# key, or a short-lived OAuth access token. https://console.cloud.google.com/
JOBBORED_GOOGLE_SERVICE_ACCOUNT_JSON=
JOBBORED_GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_ACCESS_TOKEN=

# --- Static file serving (optional) ---
# Set JOBBORED_SERVE_STATIC=1 to also serve the dashboard from this server, or
# point JOBBORED_STATIC_ROOT at the directory to serve. Leave unset in dev
# (the dashboard runs on its own dev-server at :8080).
JOBBORED_SERVE_STATIC=
JOBBORED_STATIC_ROOT=

# --- Candidate profile path (optional) ---
# Override the path to the canonical job-hunt profile.md used for materials.
# Defaults to integrations/hermes-job-hunt/profile/profile.md.
JOBBORED_PROFILE_PATH=

# --- Hermes materials integration (optional, local-only) ---
# Only needed if you run the optional Hermes resume/cover-letter workflow.
# Absolute paths; defaults resolve under the repo + ~/.hermes. See
# integrations/hermes-job-hunt/README.md.
HERMES_ROOT=
HERMES_JOB_HUNT_ROOT=
HERMES_APPLICATIONS_ROOT=
HERMES_RESUME_TEMPLATE_DIR=
HERMES_MATERIALS_REQUEST_BIN=
HERMES_LOGO_RESOLVER_SCRIPT=

# --- Discovery worker handoff (optional) ---
# Where the server reads the local discovery worker config/env, and the worker's
# Gemini key / Google service-account when the server proxies to it. Defaults
# resolve under ~/.jobbored/browser-use-discovery/.
BROWSER_USE_DISCOVERY_CONFIG_PATH=
DISCOVERY_CONFIG_PATH=
DISCOVERY_WORKER_CONFIG_PATH=
JOBBORED_WORKER_CONFIG_PATH=
BROWSER_USE_DISCOVERY_GEMINI_API_KEY=
BROWSER_USE_DISCOVERY_GOOGLE_SERVICE_ACCOUNT_FILE=
