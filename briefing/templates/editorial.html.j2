<!DOCTYPE html>
<html lang="en" data-voice="editorial" data-density="standard" data-palette="riso">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<meta name="color-scheme" content="light">
<title>Briefing · {{ window_label }}</title>
<style>
  :root {
    /* Warm-paper light palette — editorial, colorful */
    --bg: #F4ECDB;          /* warm cream */
    --surface: #FFFFFF;
    --line: #DFD3B8;        /* warm beige rule */
    --line-soft: #ECE2C8;
    --text: #1C1812;        /* warm near-black */
    --muted: #756B59;
    --muted-2: #ADA289;

    /* Per-section editorial accents */
    --c-jobs:  #C9461F;     /* terracotta */
    --c-cal:   #2A5AA6;     /* deep indigo */
    --c-inbox: #2E7A45;     /* forest green */

    /* Action + status */
    --accent: var(--c-jobs);
    --green:  #2E7A45;
    --red:    #B83A2E;
    --blue:   #2A5AA6;
    --amber:  #B9821A;
    --lilac:  #6B4FA0;

    /* Soft tints for chips/fills (lifted from the section accents) */
    --tint-jobs:  #F6D9CB;
    --tint-cal:   #D5E1F2;
    --tint-inbox: #D4E6D2;
    --tint-amber: #F4E1B6;

    --serif: "Tiempos Text", "Tiempos", "Charter", "Iowan Old Style", Georgia, "Times New Roman", serif;
    --sans: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Segoe UI", system-ui, sans-serif;
    --mono: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    --pad: clamp(20px, 5vw, 56px);
    --rule: 1px solid var(--line);
    --rule-soft: 1px solid var(--line-soft);
  }

  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: var(--bg); color: var(--text); }
  body {
    font-family: var(--sans);
    font-size: 15px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    font-feature-settings: "ss01", "cv11";
    font-variant-numeric: tabular-nums;
  }
  a { color: inherit; text-decoration: none; }
  hr { border: 0; border-top: var(--rule); margin: 0; }

  .page { max-width: 880px; margin: 0 auto; padding: 28px var(--pad) 80px; }

  /* ---------- 1. HEADER STRIP ---------- */
  .head {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 16px; padding-bottom: 14px; border-bottom: var(--rule); flex-wrap: wrap;
  }
  .head__mark { font-family: var(--serif); font-size: 13px; letter-spacing: 0.14em;
                text-transform: uppercase; color: var(--muted); }
  .head__mark b { color: var(--text); font-weight: 500; letter-spacing: 0.04em;
                  text-transform: none; font-family: var(--sans); font-size: 13px; }
  .head__meta { font-family: var(--mono); font-size: 11.5px; color: var(--muted); letter-spacing: 0.02em; }
  .head__meta .dot { display: inline-block; width: 4px; height: 4px; border-radius: 50%;
                     background: var(--muted-2); vertical-align: middle; margin: 0 8px; }

  /* ---------- 2. HEADLINE ---------- */
  .headline { padding: 36px 0 28px; border-bottom: var(--rule); position: relative; }
  .headline--urgent { padding-left: 18px; margin-left: -18px; border-left: 3px solid var(--accent); }
  .headline__label { font-family: var(--mono); font-size: 10.5px; text-transform: uppercase;
                     letter-spacing: 0.18em; color: var(--muted); margin-bottom: 18px; }
  .headline--urgent .headline__label { color: var(--accent); }
  .headline__label .pulse {
    display: inline-block; width: 7px; height: 7px; border-radius: 50%;
    background: var(--accent); margin-right: 9px; vertical-align: middle;
    transform: translateY(-1px);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent) 22%, transparent);
  }
  .headline__text {
    font-family: var(--serif); font-weight: 400;
    font-size: clamp(26px, 5.4vw, 40px); line-height: 1.22;
    letter-spacing: -0.012em; margin: 0; text-wrap: balance; color: var(--text);
  }

  /* ---------- 3. DELTA STRIP ---------- */
  .deltas { padding: 18px 0 6px; border-bottom: var(--rule);
            display: flex; flex-wrap: wrap; gap: 8px 6px; align-items: center; }
  .deltas__label { font-family: var(--mono); font-size: 10.5px; text-transform: uppercase;
                   letter-spacing: 0.18em; color: var(--muted); margin-right: 8px; }
  .chip {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 5px 12px; border: 1px solid transparent; border-radius: 999px;
    font-size: 12.5px; color: var(--text); background: var(--surface);
    line-height: 1; white-space: nowrap;
  }
  .chip::before { content: ""; width: 6px; height: 6px; border-radius: 50%;
                  background: currentColor; opacity: 0.7; }
  .chip--new      { background: var(--tint-cal);   color: var(--c-cal);   }
  .chip--changed  { background: var(--tint-amber); color: #7A5500;        }
  .chip--resolved { background: var(--tint-inbox); color: var(--c-inbox); }
  .chip--empty    { color: var(--muted); border-style: dashed; border-color: var(--line); background: transparent; }
  .chip--empty::before { display: none; }

  /* ---------- SECTION HEAD ---------- */
  .section { padding: 36px 0 8px; border-bottom: var(--rule); }
  .section:last-of-type { border-bottom: 0; }
  .section__head { display: flex; align-items: baseline; justify-content: space-between;
                   gap: 12px; margin-bottom: 22px; }
  .section__title { font-family: var(--serif); font-weight: 400; font-size: 24px;
                    letter-spacing: -0.005em; margin: 0;
                    display: flex; align-items: baseline; gap: 14px; }
  .section__title .num { font-family: var(--serif); font-style: italic; font-weight: 400;
                         font-size: 30px; letter-spacing: -0.02em;
                         color: var(--muted-2); line-height: 1; }
  .section--jobs  .section__title .num { color: var(--c-jobs);  }
  .section--cal   .section__title .num { color: var(--c-cal);   }
  .section--inbox .section__title .num { color: var(--c-inbox); }
  .section__sub { font-family: var(--mono); font-size: 11px; text-transform: uppercase;
                  letter-spacing: 0.16em; color: var(--muted); }

  /* ---------- 4. JOB HUNT ---------- */
  .stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px;
           background: var(--line); border: var(--rule); border-radius: 8px;
           overflow: hidden; margin-bottom: 26px; }
  .stat { background: var(--surface); padding: 16px 16px 14px;
          display: flex; flex-direction: column; gap: 6px;
          min-height: 86px; position: relative; }
  .stat::before { content: ""; position: absolute; left: 0; top: 0; bottom: 0;
                  width: 3px; background: var(--c-jobs); opacity: 0; }
  .stat:nth-child(1)::before { opacity: 1; }
  .stat__label { font-size: 11.5px; color: var(--muted); letter-spacing: 0.02em; }
  .stat__value { font-family: var(--serif); font-size: 32px; line-height: 1;
                 letter-spacing: -0.02em; color: var(--text); }
  .stat__value .unit { font-family: var(--sans); font-size: 13px;
                       color: var(--muted); margin-left: 2px; letter-spacing: 0; }
  .stat__delta { font-family: var(--mono); font-size: 10.5px; color: var(--muted);
                 letter-spacing: 0.04em; margin-top: auto; }

  .jobs { display: flex; flex-direction: column; }
  .job { display: grid; grid-template-columns: 1fr auto; gap: 4px 14px;
         padding: 14px 0; border-top: var(--rule-soft); position: relative; }
  .job:first-child { border-top: 0; }
  .job__co { font-size: 14.5px; color: var(--text); font-weight: 500; }
  .job__co .role { color: var(--muted); font-weight: 400; margin-left: 4px; }
  .job__stage { font-family: var(--mono); font-size: 10.5px; text-transform: uppercase;
                letter-spacing: 0.14em; color: var(--muted);
                align-self: center; text-align: right; }
  .job__meta { grid-column: 1 / -1; display: flex; align-items: baseline; gap: 12px;
               font-size: 12.5px; color: var(--muted); flex-wrap: wrap; }
  .job__next { color: var(--text); }
  .job__next::before { content: "→"; color: var(--muted-2); margin-right: 6px; }
  .job__ts { font-family: var(--mono); font-size: 11px; letter-spacing: 0.02em; }
  .job--stuck::before { content: ""; position: absolute; left: -10px;
                        top: 18px; bottom: 18px; width: 2px;
                        background: var(--red); opacity: 0.55; border-radius: 1px; }
  .job--stuck .job__stage::after { content: "stuck"; color: var(--red);
                                   margin-left: 10px; letter-spacing: 0.12em; }

  /* ---------- 5. CALENDAR ---------- */
  .cal { display: flex; flex-direction: column; }
  .cal__row { display: grid; grid-template-columns: 64px 1fr; gap: 18px;
              padding: 12px 0; border-top: var(--rule-soft); position: relative; }
  .cal__row:first-child { border-top: 0; }
  .cal__time { font-family: var(--mono); font-size: 12px; color: var(--muted);
               letter-spacing: 0.02em; padding-top: 2px; }
  .cal__time b { display: block; color: var(--text); font-weight: 500; font-size: 13px; }
  .cal__body { display: flex; flex-direction: column; gap: 3px; }
  .cal__title { font-size: 14.5px; color: var(--text); }
  .cal__meta { font-size: 12px; color: var(--muted); }
  .cal__meta .sep { margin: 0 8px; color: var(--muted-2); }
  .cal__prep { display: inline-flex; align-self: flex-start; font-family: var(--mono);
               font-size: 10px; color: var(--accent); background: var(--tint-jobs);
               text-transform: uppercase; letter-spacing: 0.14em;
               padding: 3px 8px; border-radius: 3px; margin-top: 4px; }
  .cal__row--conflict::before { content: ""; position: absolute;
                                left: -10px; top: 12px; bottom: 12px;
                                width: 2px; background: var(--red); border-radius: 1px; }
  .cal__row--free { opacity: 0.55; }
  .cal__row--free .cal__title { font-style: italic; color: var(--muted); font-size: 13.5px; }
  .cal__row--free .cal__body { border-left: 1px dashed var(--line);
                               padding-left: 12px; margin-left: -12px; }

  /* ---------- 6. INBOX ---------- */
  .mail { display: flex; flex-direction: column; }
  .mail__row { display: grid; grid-template-columns: 1fr auto; gap: 4px 12px;
               padding: 14px 0 14px 14px; border-top: var(--rule-soft);
               border-left: 2px solid transparent; margin-left: -14px; }
  .mail__row:first-child { border-top: 0; }
  .mail__row--reply { border-left-color: var(--accent);
                      background: linear-gradient(to right, color-mix(in oklab, var(--accent) 6%, transparent), transparent 40%); }
  .mail__from { font-size: 14px; color: var(--text); font-weight: 500; }
  .mail__when { font-family: var(--mono); font-size: 11px; color: var(--muted);
                letter-spacing: 0.02em; text-align: right; align-self: center; }
  .mail__subj { grid-column: 1 / -1; font-family: var(--serif); font-size: 15.5px;
                line-height: 1.35; color: var(--text); margin-top: 2px; }
  .mail__snip { grid-column: 1 / -1; font-size: 13px; color: var(--muted);
                line-height: 1.45; margin-top: 2px;
                display: -webkit-box; -webkit-line-clamp: 2;
                -webkit-box-orient: vertical; overflow: hidden; }
  .mail__more { padding: 14px 0 0; font-family: var(--mono); font-size: 11.5px;
                color: var(--muted); letter-spacing: 0.06em; }
  .mail__more b { color: var(--text); font-weight: 500; }

  /* ---------- EMPTY STATES ---------- */
  .empty { font-family: var(--serif); font-style: italic; color: var(--muted);
           font-size: 15px; padding: 6px 0 12px; }

  /* ---------- 7. AGENT FOOTER ---------- */
  .agents { padding: 32px 0 18px; border-top: var(--rule); margin-top: 28px; }
  .agents__label { font-family: var(--mono); font-size: 10.5px; text-transform: uppercase;
                   letter-spacing: 0.18em; color: var(--muted); margin-bottom: 12px; }
  .agents__grid { display: grid; grid-template-columns: 1fr; gap: 0; }
  .agent { display: grid; grid-template-columns: 14px 1fr auto; gap: 10px;
           align-items: baseline; padding: 7px 0; font-size: 12.5px;
           color: var(--muted); border-top: var(--rule-soft); }
  .agent:first-child { border-top: 0; }
  .agent__dot { width: 6px; height: 6px; border-radius: 50%;
                background: var(--green); align-self: center; justify-self: center; }
  .agent__dot--stale { background: var(--red); opacity: 0.7; }
  .agent__dot--idle  { background: var(--muted-2); }
  .agent__name { color: var(--text); font-weight: 500; }
  .agent__name .task { color: var(--muted); font-weight: 400; margin-left: 8px; }
  .agent__hb { font-family: var(--mono); font-size: 10.5px;
               letter-spacing: 0.04em; color: var(--muted); }

  /* ---------- 8. FOOTER LINE ---------- */
  .foot { margin-top: 18px; padding-top: 14px; border-top: var(--rule);
          display: flex; justify-content: space-between; align-items: baseline;
          gap: 12px; font-family: var(--mono); font-size: 10.5px;
          color: var(--muted); letter-spacing: 0.06em; flex-wrap: wrap; }
  .foot b { color: var(--text); font-weight: 500; }

  /* ---------- DESKTOP ---------- */
  @media (min-width: 760px) {
    .stats { grid-template-columns: repeat(4, 1fr); }
    .stat { min-height: 96px; }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 0 48px; }
    .grid-2 > .section { border-bottom: 0; padding-top: 36px; }
    .grid-2 > .section + .section { border-left: var(--rule); padding-left: 48px; }
  }
  @media (min-width: 1100px) { .page { max-width: 980px; } }

  @media print {
    :root { --bg: #fff; --text: #000; --muted: #444; --line: #ccc; --line-soft: #e5e5e5; }
    body { font-size: 12pt; }
    .headline--urgent { border-left-color: #000; }
  }

  /* ---------- PALETTE VARIANTS ---------- */
  html[data-palette="riso"] {
    --bg: #EEEDE6; --surface: #FFFFFF; --line: #D6D4C9; --line-soft: #E5E3D8;
    --text: #18181A; --muted: #6B6A66; --muted-2: #A7A59E;
    --c-jobs:  #E2356C; --c-cal: #2E3E96; --c-inbox: #1E8A6E;
    --accent: var(--c-jobs);
    --green: #1E8A6E; --red: #E2356C; --blue: #2E3E96; --amber: #C77A12;
    --tint-jobs: #FBD3DE; --tint-cal: #D1D7EE; --tint-inbox: #C7E8DD; --tint-amber: #FBE3B5;
  }

  html[data-palette="midnight"] {
    --bg: #0B0B0E; --surface: #15151A; --line: #22222A; --line-soft: #1B1B22;
    --text: #ECECEC; --muted: #8A8A93; --muted-2: #5E5E66;
    --c-jobs: #E8B339; --c-cal: #60A5FA; --c-inbox: #4ADE80;
    --accent: #E8B339;
    --green: #4ADE80; --red: #F87171; --blue: #60A5FA; --amber: #E8B339;
    --tint-jobs:  rgba(232, 179, 57, 0.16);
    --tint-cal:   rgba(96, 165, 250, 0.16);
    --tint-inbox: rgba(74, 222, 128, 0.16);
    --tint-amber: rgba(232, 179, 57, 0.16);
  }
  html[data-palette="midnight"] .stat { background: var(--bg); }
  html[data-palette="midnight"] .chip--changed { color: #E8B339; }

  /* ---------- VOICE VARIANTS ---------- */
  html[data-voice="wire"] .headline__text { font-family: var(--mono);
    font-size: clamp(17px, 3.4vw, 24px); line-height: 1.55; letter-spacing: 0; }
  html[data-voice="wire"] .headline { padding: 24px 0; }
  html[data-voice="wire"] .headline--urgent { padding-left: 18px; }
  html[data-voice="wire"] .headline__label { letter-spacing: 0.28em; }
  html[data-voice="wire"] .section__title { font-family: var(--mono); font-size: 12px;
    text-transform: uppercase; letter-spacing: 0.22em; }
  html[data-voice="wire"] .section__title .num { font-family: var(--mono);
    font-style: normal; font-size: 12px; font-weight: 600; letter-spacing: 0.1em; }
  html[data-voice="wire"] .stat__value { font-family: var(--mono); font-size: 26px; letter-spacing: -0.01em; }
  html[data-voice="wire"] .mail__subj { font-family: var(--sans); font-size: 14.5px; font-weight: 500; }
  html[data-voice="wire"] .empty { font-family: var(--mono); font-style: normal;
    font-size: 11.5px; text-transform: uppercase; letter-spacing: 0.18em; }
  html[data-voice="wire"] .cal__row--free .cal__title { font-family: var(--mono);
    font-style: normal; text-transform: uppercase; font-size: 11px; letter-spacing: 0.18em; }

  html[data-voice="manuscript"] body { font-family: var(--serif); font-size: 16px; line-height: 1.55; }
  html[data-voice="manuscript"] .headline__text { font-style: italic; font-size: clamp(30px, 6vw, 48px); }
  html[data-voice="manuscript"] .section__title { font-style: italic; font-size: 26px; }
  html[data-voice="manuscript"] .head__mark,
  html[data-voice="manuscript"] .head__mark b { font-family: var(--serif); font-style: italic;
    text-transform: none; letter-spacing: 0; font-size: 14px; }
  html[data-voice="manuscript"] .job__co,
  html[data-voice="manuscript"] .cal__title,
  html[data-voice="manuscript"] .mail__from { font-family: var(--serif); }
  html[data-voice="manuscript"] .mail__subj { font-style: italic; }
  html[data-voice="manuscript"] .stat__label { font-family: var(--serif); font-style: italic; font-size: 13px; }

  /* ---------- DENSITY VARIANTS ---------- */
  html[data-density="compact"] { --pad: clamp(14px, 3.5vw, 32px); }
  html[data-density="compact"] body { font-size: 13.5px; }
  html[data-density="compact"] .headline { padding: 22px 0 18px; }
  html[data-density="compact"] .headline__text { font-size: clamp(20px, 4.4vw, 30px); }
  html[data-density="compact"] .section { padding: 22px 0 6px; }
  html[data-density="compact"] .section__head { margin-bottom: 14px; }
  html[data-density="compact"] .stat { padding: 12px; min-height: 70px; }
  html[data-density="compact"] .stat__value { font-size: 26px; }
  html[data-density="compact"] .stats { margin-bottom: 18px; }
  html[data-density="compact"] .job,
  html[data-density="compact"] .mail__row,
  html[data-density="compact"] .cal__row { padding-top: 10px; padding-bottom: 10px; }

  html[data-density="spread"] { --pad: clamp(28px, 7vw, 88px); }
  html[data-density="spread"] body { font-size: 16px; }
  html[data-density="spread"] .headline { padding: 60px 0 48px; }
  html[data-density="spread"] .headline__text { font-size: clamp(34px, 6.6vw, 56px); line-height: 1.18; }
  html[data-density="spread"] .section { padding: 56px 0 12px; }
  html[data-density="spread"] .section__head { margin-bottom: 30px; }
  html[data-density="spread"] .stat { padding: 22px; min-height: 112px; }
  html[data-density="spread"] .stat__value { font-size: 38px; }
  html[data-density="spread"] .job,
  html[data-density="spread"] .mail__row,
  html[data-density="spread"] .cal__row { padding-top: 18px; padding-bottom: 18px; }
</style>
</head>
<body>

<main class="page">

  <!-- 1. HEADER STRIP -->
  <header class="head">
    <div class="head__mark">The Briefing &nbsp;·&nbsp; <b>{{ window_label }}</b></div>
    <div class="head__meta">{{ generated_at }}</div>
  </header>

  <!-- 2. HEADLINE -->
  <section class="headline headline--urgent">
    <div class="headline__label"><span class="pulse"></span>Right now</div>
    <h1 class="headline__text" data-headline>{{ headline }}</h1>
  </section>

  <!-- 3. DELTA STRIP -->
  {% if deltas %}
  <section class="deltas">
    <span class="deltas__label">Since last briefing</span>
    {% for d in deltas %}
      <span class="chip chip--{{ d.kind }}">{{ d.label }}</span>
    {% endfor %}
  </section>
  {% endif %}

  <!-- 4. JOB HUNT -->
  <section class="section section--jobs">
    <div class="section__head">
      <h2 class="section__title"><span class="num">01</span>Job Hunt</h2>
      <span class="section__sub">{{ jobs.active|length }} active thread{% if jobs.active|length != 1 %}s{% endif %}</span>
    </div>

    <div class="stats">
      <div class="stat">
        <div class="stat__label">Sent today</div>
        <div class="stat__value">{{ jobs.sent_today }}</div>
        <div class="stat__delta">applications</div>
      </div>
      <div class="stat">
        <div class="stat__label">Drafts pending</div>
        <div class="stat__value">{{ jobs.drafts_pending }}</div>
        <div class="stat__delta">awaiting review</div>
      </div>
      <div class="stat">
        <div class="stat__label">Interviews this week</div>
        <div class="stat__value">{{ jobs.interviews_this_week }}</div>
        <div class="stat__delta">scheduled</div>
      </div>
      <div class="stat">
        <div class="stat__label">Response rate</div>
        <div class="stat__value">{{ jobs.response_rate_7d }}</div>
        <div class="stat__delta">last 7 days</div>
      </div>
    </div>

    <div class="jobs">
      {% for a in jobs.active %}
        <div class="job{% if a.stuck %} job--stuck{% endif %}">
          <div class="job__co">{{ a.company }}<span class="role">· {{ a.role }}</span></div>
          <div class="job__stage">{{ a.stage|title }}</div>
          <div class="job__meta">
            <span class="job__ts">{{ a.last_action }}</span>
            <span class="job__next">{{ a.next_action }}</span>
          </div>
        </div>
      {% else %}
        <div class="empty">No active applications{% if jobs._error %} — source unreachable{% endif %}.</div>
      {% endfor %}
    </div>
  </section>

  <div class="grid-2">

    <!-- 5. CALENDAR -->
    <section class="section section--cal">
      <div class="section__head">
        <h2 class="section__title"><span class="num">02</span>Calendar</h2>
        <span class="section__sub">Next 24 hours</span>
      </div>

      <div class="cal">
        {% for e in calendar.upcoming %}
          <div class="cal__row{% if e.conflict %} cal__row--conflict{% endif %}">
            <div class="cal__time">
              <b>{{ e.time }}</b>
              {{ e.duration }}
            </div>
            <div class="cal__body">
              <div class="cal__title">{{ e.title }}</div>
              {% if e.location %}<div class="cal__meta">{{ e.location }}</div>{% endif %}
              {% if e.prep_needed %}<div class="cal__prep">Prep needed</div>{% endif %}
            </div>
          </div>
        {% else %}
          <div class="empty">Nothing on the calendar.</div>
        {% endfor %}

        {% for b in calendar.free_blocks %}
          <div class="cal__row cal__row--free">
            <div class="cal__time"><b>{{ b.label }}</b></div>
            <div class="cal__body"><div class="cal__title">Free</div></div>
          </div>
        {% endfor %}
      </div>
    </section>

    <!-- 6. INBOX -->
    <section class="section section--inbox">
      <div class="section__head">
        <h2 class="section__title"><span class="num">03</span>Inbox</h2>
        <span class="section__sub">Important only</span>
      </div>

      <div class="mail">
        {% for m in inbox.important[:5] %}
          <div class="mail__row{% if m.requires_reply %} mail__row--reply{% endif %}">
            <div class="mail__from">{{ m.from }}</div>
            <div class="mail__when">{{ m.received }}</div>
            <div class="mail__subj">{{ m.subject }}</div>
            <div class="mail__snip">{{ m.snippet }}</div>
          </div>
        {% else %}
          <div class="empty">No important email this window.</div>
        {% endfor %}

        {% if inbox.important|length > 5 %}
          <div class="mail__more">+<b>{{ inbox.important|length - 5 }}</b> more</div>
        {% endif %}
      </div>
    </section>

  </div>

  <!-- 7. AGENT STATUS -->
  <section class="agents">
    <div class="agents__label">Agents</div>
    <div class="agents__grid">
      {% for a in agents %}
        <div class="agent">
          <span class="agent__dot{% if a.stale %} agent__dot--stale{% elif a.status == 'idle' %} agent__dot--idle{% endif %}"></span>
          <span class="agent__name">{{ a.name }}<span class="task">{{ a.current_task }}</span></span>
          <span class="agent__hb">{{ a.last_heartbeat }}</span>
        </div>
      {% else %}
        <div class="empty">No agents reporting.</div>
      {% endfor %}
    </div>
  </section>

  <!-- 8. FOOTER -->
  <footer class="foot">
    <div>Next briefing at <b>{{ next_briefing_time }} MT</b></div>
    <div>build · {{ briefing_id }}</div>
  </footer>

</main>

</body></html>
