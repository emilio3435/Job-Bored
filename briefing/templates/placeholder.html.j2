<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Briefing · {{ window_label }}</title>
<style>
  /* PLACEHOLDER STYLES — swap this whole file for your Claude-designed template. */
  :root {
    --bg: #0B0B0E; --surface: #15151A; --text: #ECECEC; --muted: #8A8A93;
    --accent: #E8B339; --ok: #4ADE80; --warn: #F87171; --info: #60A5FA;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { background: var(--bg); color: var(--text); font: 15px/1.5 system-ui, -apple-system, sans-serif; }
  body { padding: 24px; max-width: 720px; margin: 0 auto; }
  .header { display: flex; justify-content: space-between; align-items: baseline;
            color: var(--muted); font-size: 13px; margin-bottom: 24px; letter-spacing: 0.04em; text-transform: uppercase; }
  .headline { font-family: Georgia, serif; font-size: 26px; line-height: 1.25; margin-bottom: 20px;
              padding-bottom: 20px; border-bottom: 1px solid #2a2a31; }
  .deltas { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 28px; }
  .pill { font-size: 11px; padding: 4px 10px; border-radius: 999px; background: var(--surface);
          color: var(--muted); border: 1px solid #2a2a31; }
  .pill.new { color: var(--info); border-color: rgba(96,165,250,0.3); }
  .pill.changed { color: var(--accent); border-color: rgba(232,179,57,0.3); }
  .pill.resolved { color: var(--ok); border-color: rgba(74,222,128,0.3); }
  .panel { margin-bottom: 32px; }
  .panel h2 { font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;
              color: var(--muted); margin-bottom: 12px; font-weight: 600; }
  .stat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-bottom: 16px; }
  .stat { background: var(--surface); padding: 12px; border-radius: 8px; }
  .stat .v { font-size: 22px; font-variant-numeric: tabular-nums; }
  .stat .k { font-size: 11px; color: var(--muted); margin-top: 4px; }
  .row { display: flex; justify-content: space-between; padding: 10px 0;
         border-bottom: 1px solid #1f1f25; gap: 12px; }
  .row:last-child { border-bottom: none; }
  .row .meta { color: var(--muted); font-size: 12px; }
  .row.stuck { border-left: 2px solid var(--warn); padding-left: 10px; margin-left: -12px; }
  .row.reply { border-left: 2px solid var(--accent); padding-left: 10px; margin-left: -12px; }
  .row.conflict { border-left: 2px solid var(--warn); padding-left: 10px; margin-left: -12px; }
  .row.prep { border-left: 2px solid var(--info); padding-left: 10px; margin-left: -12px; }
  .free-block { color: var(--muted); font-size: 12px; padding: 6px 0; font-style: italic; }
  .dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 8px;
         background: var(--ok); vertical-align: middle; }
  .dot.stale { background: var(--warn); }
  .agents .row { font-size: 12px; color: var(--muted); padding: 6px 0; }
  .empty { color: var(--muted); font-size: 13px; font-style: italic; padding: 8px 0; }
  .footer { margin-top: 40px; padding-top: 16px; border-top: 1px solid #2a2a31;
            color: var(--muted); font-size: 11px; display: flex; justify-content: space-between; }
  @media (max-width: 480px) {
    .stat-grid { grid-template-columns: repeat(2, 1fr); }
    .headline { font-size: 22px; }
  }
</style>
</head>
<body>
  <div class="header">
    <span>Briefing · {{ window_label }}</span>
    <span>{{ generated_at }}</span>
  </div>

  <h1 class="headline" data-headline>{{ headline }}</h1>

  {% if deltas %}
  <div class="deltas">
    {% for d in deltas %}<span class="pill {{ d.kind }}">{{ d.label }}</span>{% endfor %}
  </div>
  {% endif %}

  <!-- ────── Job Hunt ────── -->
  <div class="panel">
    <h2>Job Hunt</h2>
    <div class="stat-grid">
      <div class="stat"><div class="v">{{ jobs.sent_today }}</div><div class="k">Sent today</div></div>
      <div class="stat"><div class="v">{{ jobs.drafts_pending }}</div><div class="k">Drafts pending</div></div>
      <div class="stat"><div class="v">{{ jobs.interviews_this_week }}</div><div class="k">Interviews 7d</div></div>
      <div class="stat"><div class="v">{{ jobs.response_rate_7d }}</div><div class="k">Response rate</div></div>
    </div>
    {% if jobs.active %}
      {% for a in jobs.active %}
      <div class="row {% if a.stuck %}stuck{% endif %}">
        <div>
          <div>{{ a.company }} · <span style="color: var(--muted)">{{ a.role }}</span></div>
          <div class="meta">{{ a.stage }} · last action {{ a.last_action }}</div>
        </div>
        <div class="meta">{{ a.next_action }}</div>
      </div>
      {% endfor %}
    {% else %}
      <div class="empty">No active applications {% if jobs._error %}(source unreachable){% endif %}.</div>
    {% endif %}
  </div>

  <!-- ────── Calendar ────── -->
  <div class="panel">
    <h2>Next 24 hours</h2>
    {% if calendar.upcoming %}
      {% for e in calendar.upcoming %}
      <div class="row {% if e.conflict %}conflict{% elif e.prep_needed %}prep{% endif %}">
        <div>
          <div>{{ e.title }}</div>
          <div class="meta">{{ e.time }} · {{ e.duration }} · {{ e.location }}</div>
        </div>
      </div>
      {% endfor %}
      {% if calendar.free_blocks %}
        {% for b in calendar.free_blocks %}
        <div class="free-block">↓ Free: {{ b.label }}</div>
        {% endfor %}
      {% endif %}
    {% else %}
      <div class="empty">Nothing on the calendar.</div>
    {% endif %}
  </div>

  <!-- ────── Inbox ────── -->
  <div class="panel">
    <h2>Important email</h2>
    {% if inbox.important %}
      {% for e in inbox.important[:5] %}
      <div class="row {% if e.requires_reply %}reply{% endif %}">
        <div>
          <div>{{ e.subject }}</div>
          <div class="meta">{{ e.from }} · {{ e.received }}</div>
          <div class="meta" style="margin-top: 4px;">{{ e.snippet }}</div>
        </div>
      </div>
      {% endfor %}
      {% if inbox.important|length > 5 %}
        <div class="empty">+{{ inbox.important|length - 5 }} more</div>
      {% endif %}
    {% else %}
      <div class="empty">No important email this window.</div>
    {% endif %}
  </div>

  <!-- ────── Agent status ────── -->
  <div class="panel agents">
    <h2>Agents</h2>
    {% if agents %}
      {% for a in agents %}
      <div class="row">
        <div><span class="dot {% if a.stale %}stale{% endif %}"></span>{{ a.name }}
             <span style="color: var(--text)">· {{ a.status }}</span></div>
        <div>{{ a.current_task }} · <span style="color: var(--text)">{{ a.last_heartbeat }}</span></div>
      </div>
      {% endfor %}
    {% else %}
      <div class="empty">No agents reporting.</div>
    {% endif %}
  </div>

  <div class="footer">
    <span>Next briefing at {{ next_briefing_time }}</span>
    <span>{{ briefing_id }}</span>
  </div>
</body>
</html>
