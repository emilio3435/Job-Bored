# Copy to ~/.briefing/.env and fill in.

# Anthropic — for the headline LLM call. If absent, falls back to deterministic headline.
ANTHROPIC_API_KEY=

# Telegram — reuses the bot from ~/.hermes/.env if you leave this blank.
# Override only if you want a different chat/thread for briefings.
TELEGRAM_BOT_TOKEN=
BRIEFING_CHAT_ID=
BRIEFING_THREAD_ID=

# Job-Bored Express server base URL (local on always-on box).
JOBBORED_BASE=http://127.0.0.1:8787

# Where rendered HTML lands. Tailscale-serve this dir to expose to phone.
BRIEFING_OUT_DIR=/Users/USERNAME/Briefings

# Public URL prefix for links sent to Telegram (your tailscale-serve URL).
BRIEFING_PUBLIC_BASE=https://always-on.tail-scale.ts.net/briefings

# Comma-separated heartbeat sources: "displayname|url,displayname|url"
# Each URL must return JSON: { agent, status, current_task, timestamp }
HEARTBEAT_SOURCES=laptop-hermes|http://laptop.tail-scale.ts.net:9999/agents/hermes-job-hunt.json

# Google OAuth for Gmail + Calendar (leave blank for stubs).
# Setup: https://developers.google.com/gmail/api/quickstart/python
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
